# functions 환경변수 템플릿 (Cloud Functions 런타임)
# 이 파일을 .env 로 복사한 뒤 사용하세요. .env 는 .gitignore에 포함되어 있습니다.
#
# 사용법:
#   cp functions/env.template functions/.env
#
# 주의:
#   - 프로덕션 배포 시에는 이 .env 파일이 아닌 Firebase Functions config
#     (firebase functions:config:set ... / Secret Manager) 를 사용하세요.
#   - 이 템플릿은 firebase emulators:start 로컬 데모용 기본값입니다.

# ---------- Firebase Emulator Suite ----------
# 주의: 아래 4개 변수는 Firebase Functions v6 가 reserved keyword 로 거부합니다.
# firebase emulators:start 가 functions 런타임에 자동 주입하므로 .env 에 적지
# 마세요. 만약 functions 외부에서 emulator 에 접근하는 별도 스크립트를 작성하는
# 경우 그 스크립트의 셸 환경에만 export 해 쓰세요.
#   FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
#   FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
#   FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
#   GCLOUD_PROJECT=demo-cleartoship  (emulator 가 firebase emulators:start --project 인자로 자동 설정)

# Functions 런타임이 "emulator 모드" 임을 알리는 표준 플래그.
# enqueue-audit-task.ts 는 이 값이 'true' 일 때 Cloud Tasks 를 우회하고
# AUDIT_WORKER_URL 로 직접 POST 합니다 (dev-direct path).
FUNCTIONS_EMULATOR=true

# ---------- Audit Worker (로컬) ----------
# 로컬 audit-worker 가 바인딩된 URL.
# Firestore emulator 가 8080 을 점유하므로 워커는 WORKER_PORT=8787 로
# 실행합니다 (docs/runbook/mvp-demo.md §4.5 참조).
AUDIT_WORKER_URL=http://localhost:8787

# ---------- Cloud Tasks (프로덕션 전용 — emulator 모드에서는 무시됨) ----------
# 아래 값은 functions/src/triggers/on-audit-run-created.ts 가 참조합니다.
# emulator 모드(FUNCTIONS_EMULATOR=true)에서는 AUDIT_WORKER_URL 만 있으면
# 동작하므로 다음 변수들은 비워두거나 placeholder 로 남겨도 됩니다.
CLOUD_TASKS_PROJECT=
CLOUD_TASKS_LOCATION=asia-northeast3
CLOUD_TASKS_QUEUE=audit-jobs
AUDIT_WORKER_INVOKER_SA=

# Production 배포 시 별도로 GCP_PROJECT 도 설정해야 합니다 (CLOUD_TASKS_PROJECT
# 가 비어있을 때 fallback 으로 사용됨 — on-audit-run-created.ts:29).
GCP_PROJECT=
