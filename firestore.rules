rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function runOwner(runId) {
      return get(/databases/$(database)/documents/auditRuns/$(runId)).data.ownerId == request.auth.uid;
    }

    // --- Users ---
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /projects/{projectId} {
        allow read, write: if isOwner(uid);
      }
    }

    // --- Audit Runs (top-level for cross-user worker access) ---
    match /auditRuns/{runId} {
      allow read: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Clients may only create runs in PENDING state with their own ownerId.
      allow create: if isSignedIn()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.status == 'PENDING';

      // Updates/deletes are server-side only (Admin SDK via worker / functions).
      allow update, delete: if false;

      match /toolResults/{toolResultId} {
        allow read: if isSignedIn() && runOwner(runId);
        allow write: if false;
      }

      match /findings/{findingId} {
        allow read: if isSignedIn() && runOwner(runId);
        allow write: if false;
      }

      match /evidences/{evidenceId} {
        allow read: if isSignedIn() && runOwner(runId);
        allow write: if false;
      }

      match /featureGraph/{docId} {
        allow read: if isSignedIn() && runOwner(runId);
        allow write: if false;
      }

      match /report/{docId} {
        allow read: if isSignedIn() && runOwner(runId);
        allow write: if false;
      }

      match /improvementPrd/{docId} {
        allow read: if isSignedIn() && runOwner(runId);
        allow write: if false;
      }

      match /uploadedDocuments/{docId} {
        allow read: if isSignedIn() && runOwner(runId);
        allow write: if false;
      }

      // T2.6 (02-E) False-positive feedback. The owner of the audit run may
      // create / update / delete a feedback doc for any finding under it.
      // The id mirrors the finding id, so each finding has at most one
      // feedback doc per run. The doc must be authored by the same signed-in
      // user (markedBy = uid) so the future weight-decay job can dedupe.
      match /feedback/{findingId} {
        allow read: if isSignedIn() && runOwner(runId);
        allow create: if isSignedIn()
                      && runOwner(runId)
                      && request.resource.data.markedBy == request.auth.uid;
        allow update: if isSignedIn()
                      && runOwner(runId)
                      && request.resource.data.markedBy == request.auth.uid;
        allow delete: if isSignedIn() && runOwner(runId);
      }
    }

    // --- Progress Events (live UI subscriptions) ---
    match /progressEvents/{runId}/events/{eventId} {
      allow read: if isSignedIn() && runOwner(runId);
      allow write: if false;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
