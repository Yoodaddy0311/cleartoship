# apps/web 환경변수 템플릿
# 이 파일을 .env.local 로 복사한 뒤 YOUR_* 플레이스홀더를 실제 값으로 교체하세요.
# .env.local 은 .gitignore에 포함되어 있습니다 — 절대 커밋하지 마세요.
#
# 사용법:
#   cp apps/web/env.template apps/web/.env.local

# ---------- Firebase Client (브라우저 공개 가능) ----------
# Firebase 콘솔 > Project Settings > Your apps > SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# ---------- Emulator 스위치 ----------
# 로컬 개발 시: 1 / 프로덕션: 0
NEXT_PUBLIC_USE_EMULATORS=1
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# ---------- Firebase Admin SDK (서버 사이드 전용 — 절대 NEXT_PUBLIC_ 붙이지 말 것) ----------
# 로컬 개발: service account JSON 경로. 프로덕션(WIF): 비워두세요.
GOOGLE_APPLICATION_CREDENTIALS=

# ---------- Cloud Tasks / Worker (Sprint 1+ — emulator 모드에서는 불필요) ----------
CLOUD_TASKS_PROJECT=YOUR_PROJECT
CLOUD_TASKS_LOCATION=asia-northeast3
CLOUD_TASKS_QUEUE=audit-jobs
AUDIT_WORKER_URL=https://audit-worker-XXXXX-an.a.run.app
AUDIT_WORKER_INVOKER_SA=cloud-run-invoker@YOUR_PROJECT.iam.gserviceaccount.com
