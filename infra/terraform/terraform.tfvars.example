# Copy this file to terraform.tfvars and fill in real values.
# DO NOT commit terraform.tfvars (it contains billing IDs).

project_id      = "cleartoship-prod"
region          = "asia-northeast3"
billing_account = "XXXXXX-XXXXXX-XXXXXX"

# Optional. If empty, defaults to "<project_id>.appspot.com" (Firebase default Storage bucket).
uploads_bucket_name = ""

# GitHub repo that the WIF provider will trust. Leave github_owner empty to disable repo restriction (NOT recommended).
github_owner = "your-github-org-or-user"
github_repo  = "ClearToShip"

# Optional reference value. Not used to create resources; surfaced via outputs only.
worker_image = ""
